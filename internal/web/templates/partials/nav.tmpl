{{define "nav"}}
<nav class="site-nav" aria-label="Main navigation">
    <ul>
        <li>
            <strong><a class="site-nav__brand contrast" href="/">Book Social</a></strong>
        </li>
    </ul>

    {{if .Nav}}
        <ul class="site-nav__items">
            {{range .Nav}}
                <li>
                    <a href="{{.Href}}"{{if eq $.ActiveNav .Key}} aria-current="page"{{end}}>{{.Label}}</a>
                </li>
            {{end}}
        </ul>
    {{else}}
        <ul class="site-nav__items">
            <li><a href="/">Home</a></li>
        </ul>
    {{end}}
</nav>
{{end}}
