{{define "book_card"}}
    <article class="book-card">
        <a class="book-card__cover {{.CoverClass}}" href="{{.BookURL}}" aria-label="Open {{.Title}}">
            <span class="book-card__cover-book" aria-hidden="true">
                <span class="book-cover__brand">Book Social</span>
                <span class="book-cover__title">{{.Title}}</span>
                <span class="book-cover__rule"></span>
            </span>
        </a>

        <div class="book-card__body">
            <h2 class="book-card__title">
                <a href="{{.BookURL}}">{{.Title}}</a>
            </h2>

            <p class="book-card__meta">
                by <a href="{{.AuthorURL}}">{{.AuthorName}}</a>
                {{if and .UseHTMXFilters .AuthorFilterURL}}
                    <a href="{{.AuthorFilterURL}}" hx-get="{{.AuthorFilterURL}}" hx-target="#book-list" hx-swap="innerHTML" hx-push-url="true" aria-label="Filter catalog by {{.AuthorName}}">Filter</a>
                {{end}}
            </p>

            {{if .GenreName}}
                <p class="book-card__genre">
                    {{if .UseHTMXFilters}}
                        <a href="{{.GenreURL}}" hx-get="{{.GenreURL}}" hx-target="#book-list" hx-swap="innerHTML" hx-push-url="true">{{.GenreName}}</a>
                    {{else}}
                        <a href="{{.GenreURL}}">{{.GenreName}}</a>
                    {{end}}
                </p>
            {{end}}

            {{if .Description}}
                <p class="book-card__description">{{.Description}}</p>
            {{end}}

            {{if .ShowDetailsLink}}
                <p class="book-card__footer">
                    <a href="{{.BookURL}}" aria-label="View details for {{.Title}}">View details</a>
                </p>
            {{end}}
        </div>
    </article>
{{end}}
