{{define "title"}}{{.Title}}{{end}}

{{define "main"}}
    <section class="home-hero">
        <div class="home-hero__content">
            <p class="eyebrow">A social catalog for curious readers</p>
            <h1>Discover books worth talking about.</h1>
            <p class="home-hero__lead">
                Browse a growing catalog of books, follow paths through authors and genres,
                and get a clear starting point for what to read next.
            </p>

            <div class="home-hero__actions" aria-label="Primary actions">
                <a href="/books" role="button">Browse catalog</a>
                <a class="secondary" href="#genres-heading" role="button">Explore genres</a>
            </div>

            <p class="home-hero__note">Available now: catalog, book pages, author pages, and genre browsing.</p>
        </div>

        <div class="home-hero__panel" aria-label="Book Social highlights">
            <div class="hero-stat">
                <strong>Catalog first</strong>
                <span>Books, authors, and genres are browsable today.</span>
            </div>
            <div class="hero-stat">
                <strong>Reader-friendly</strong>
                <span>Short descriptions keep discovery quick.</span>
            </div>
            <div class="hero-stat">
                <strong>Social later</strong>
                <span>Profiles, lists, and reviews are planned next.</span>
            </div>
        </div>
    </section>

    <section aria-labelledby="latest-books-heading">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Recently added</p>
                <h2 id="latest-books-heading">Latest books</h2>
            </div>
            <a href="/books">View catalog</a>
        </div>

        <div class="grid book-grid">
            {{range .LatestBooks}}
                {{template "book_card" .}}
            {{end}}
        </div>
    </section>

    <section aria-labelledby="genres-heading">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Browse by mood</p>
                <h2 id="genres-heading">Genres</h2>
            </div>
        </div>

        <div class="grid">
            {{range .Genres}}
                <article class="compact-card">
                    <h3><a href="{{.URL}}">{{.Name}}</a></h3>
                    <p>{{.Description}}</p>
                </article>
            {{end}}
        </div>
    </section>

    <section aria-labelledby="why-heading">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Why Book Social</p>
                <h2 id="why-heading">Built for book discovery first</h2>
            </div>
        </div>

        <div class="grid">
            {{range .Benefits}}
                <article class="compact-card">
                    <h3>{{.Title}}</h3>
                    <p>{{.Description}}</p>
                </article>
            {{end}}
        </div>
    </section>

    <section aria-labelledby="coming-soon-heading">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Roadmap</p>
                <h2 id="coming-soon-heading">Coming soon</h2>
            </div>
        </div>

        <div class="grid">
            {{range .ComingSoon}}
                <article class="compact-card">
                    <h3>{{.Title}}</h3>
                    <p>{{.Description}}</p>
                </article>
            {{end}}
        </div>
    </section>
{{end}}
